# ECPM Environment Configuration
# Copy to .env and fill in real values. .env is gitignored and will not be committed.

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=ecpm
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=ecpm

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── API Keys (obtain from respective portals) ────────────────────────
FRED_API_KEY=
BEA_API_KEY=
CENSUS_API_KEY=

# ── JWT Authentication ────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_RANDOM_64_CHAR_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Admin credentials ────────────────────────────────────────────────
# Generate hash: python scripts/create_admin.py
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ── Application ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
FETCH_SCHEDULE_HOUR=6
FETCH_SCHEDULE_MINUTE=0
# ── Training Token ───────────────────────────────────────────────────
# Static bearer token for triggering model training via API.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
TRAINING_TOKEN=

# ── Production / reverse proxy ───────────────────────────────────────
# ENVIRONMENT=production
# Comma-separated browser origins (required for credentialed cross-origin calls)
# CORS_ORIGINS=https://your.public.hostname
# Optional CSP connect-src additions if UI and API are on different hosts
# CSP_CONNECT_SRC_EXTRA=https://api.example.com
# Caddy site address (public DNS for ACME, or :80 for local HTTP only)
# CADDY_DOMAIN=ecpm.example.com
# Frontend build: leave empty for same-origin; else absolute API base URL
# NEXT_PUBLIC_API_URL=
# Uvicorn worker count (used by docker-compose.prod.yml)
# UVICORN_WORKERS=4
# SEC EDGAR User-Agent (identify your app per https://www.sec.gov/os/webmaster-faq#code-support )
# EDGAR_USER_AGENT=
